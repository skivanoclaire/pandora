# ===========================================
# PANDORA - Environment Configuration
# ===========================================
# Salin file ini menjadi .env dan sesuaikan nilainya
# cp .env.example .env

# --- Application ---
APP_NAME=PANDORA
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost

# --- Database (PostgreSQL + PostGIS) ---
DB_HOST=pandora-db
DB_PORT=5432
DB_DATABASE=pandora
DB_USERNAME=pandora
DB_PASSWORD=secret

# --- Redis ---
REDIS_HOST=pandora-redis
REDIS_PORT=6379
REDIS_PASSWORD=null

# --- Laravel Cache & Queue ---
CACHE_STORE=redis
QUEUE_CONNECTION=redis
SESSION_DRIVER=redis

# --- Analytics Service (FastAPI) ---
ANALYTICS_SERVICE_URL=http://pandora-analytics:8000

# --- Nginx ---
NGINX_PORT=80
NGINX_SSL_PORT=443
